<UserControl x:Class="Wps.Module.Hosting.Ui.ServiceControlPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1A1F25">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Styles UI partagés (switch toggle, etc.) — SharedStyles dans le même
                     SDK Wps.Host.Sdk : on référence avec un pack URI relatif au même assembly. -->
                <ResourceDictionary Source="pack://application:,,,/Wps.Host.Sdk;component/Resources/SharedStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="ActionBtn" TargetType="Button">
                <Setter Property="Padding" Value="14,7" />
                <Setter Property="Margin" Value="0,0,8,0" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="Background" Value="#3A7BBF" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                    CornerRadius="5" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.85" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.6" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.4" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="SecondaryBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
                <Setter Property="Background" Value="#556270" />
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <ScrollViewer.Resources>
            <!-- Style ScrollBar custom (cohérent avec wipiLOG) — appliqué uniquement à
                 ce ScrollViewer via Resources locales pour ne pas affecter les autres
                 ScrollBar de la pageslot ou du host. -->
            <Style TargetType="ScrollBar" BasedOn="{StaticResource WpsScrollBarStyle}" />
        </ScrollViewer.Resources>
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- ====== Header (nom + version) ====== -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                <Image x:Name="ServiceIcon" Width="36" Height="36"
                       VerticalAlignment="Center" Margin="0,0,12,0" />
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="ServiceTitle" Text="" FontSize="22" FontWeight="SemiBold"
                               Foreground="White" />
                    <TextBlock x:Name="ServiceSubtitle" Text="" FontSize="12"
                               Foreground="#8B94A0" Margin="0,2,0,0" />
                </StackPanel>
            </StackPanel>

            <!-- ====== Statut Running/Stopped (+ zone d'erreur déploiement) ====== -->
            <Border Grid.Row="1" Background="#22272E" CornerRadius="6" Padding="14"
                    Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Statut classique : pastille + texte ("En fonctionnement", "Arrêté", etc.) -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Ellipse x:Name="StatusDot" Width="10" Height="10"
                                 VerticalAlignment="Center" Margin="0,0,10,0"
                                 Fill="#80909A" />
                        <TextBlock x:Name="StatusText" Text="Arrêté"
                                   Foreground="#D0D6DE" FontSize="14" VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- Zone d'erreur de déploiement : à droite, masquée par défaut. Affichée
                         en rouge quand WpsDeployVerifier détecte un déploiement invalide
                         (manifest absent, fichier manquant, fichier corrompu...). Évite que
                         l'utilisateur tombe sur des dialogues runtime cryptiques. -->
                    <TextBlock x:Name="DeployErrorText" Grid.Column="1"
                               Foreground="#E14D4D" FontSize="13"
                               VerticalAlignment="Center" HorizontalAlignment="Right"
                               TextTrimming="CharacterEllipsis"
                               Margin="16,0,0,0"
                               Visibility="Collapsed" />
                </Grid>
            </Border>

            <!-- ====== Toggle Daemon (switch style partagé) ====== -->
            <Border Grid.Row="2" Background="#22272E" CornerRadius="6" Padding="14"
                    Margin="0,0,0,12">
                <StackPanel Orientation="Horizontal">
                    <ToggleButton x:Name="DaemonToggle"
                                  Style="{StaticResource WpsSwitchToggleStyle}"
                                  IsChecked="True"
                                  VerticalAlignment="Center"
                                  Click="OnDaemonToggleClick" />
                    <TextBlock Text="Démarrer le service au lancement"
                               Foreground="White" FontSize="14"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0" />
                </StackPanel>
            </Border>

            <!-- ====== Actions ====== -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,12">
                <Button x:Name="SettingsBtn" Content="Paramètres"
                        Style="{StaticResource SecondaryBtn}"
                        Click="OnSettingsClick" />
                <Button x:Name="RestartBtn" Content="Redémarrer"
                        Style="{StaticResource ActionBtn}"
                        Click="OnRestartClick" />
                <Button x:Name="StopBtn" Content="Arrêter"
                        Style="{StaticResource SecondaryBtn}"
                        Click="OnStopClick" />
            </StackPanel>

            <!-- ====== Description Markdown ====== -->
            <TextBlock Grid.Row="4" Text="Description"
                       Foreground="#8B94A0" FontSize="12" Margin="0,8,0,4" />
            <Border Grid.Row="5" Background="#22272E" CornerRadius="6" Padding="14">
                <TextBlock x:Name="ServiceDescription" Text=""
                           Foreground="#D0D6DE" FontSize="12"
                           TextWrapping="Wrap" />
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
