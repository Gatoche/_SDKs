<!--
  SharedStyles.xaml — ResourceDictionary partagé entre les hosts wipiSoft (ModuloSlot,
  futur wipiTools, etc.). Contient les styles UI communs (switch toggle, futurs cards,
  boutons, etc.).

  Référencement depuis un host consommateur (App.xaml ou n'importe quel UserControl) :

      <ResourceDictionary.MergedDictionaries>
          <ResourceDictionary Source="pack://application:,,,/Wps.Host.Sdk;component/Resources/SharedStyles.xaml" />
      </ResourceDictionary.MergedDictionaries>

  Tous les styles sont préfixés "Wps" pour éviter les collisions avec les ressources locales
  du consommateur.
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
      Switch toggle — bascule on/off au look "iOS-like" cohérent avec wipiLOG.
      ToggleButton 40x20, ellipse blanche qui glisse de gauche (off, fond noir) à droite
      (on, fond #3A7BBF). Cible : ToggleButton (et donc CheckBox aussi par héritage si on
      surcharge le Style).
    -->
    <Style x:Key="WpsSwitchToggleStyle" TargetType="ToggleButton">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="OuterBorder"
                            Width="40" Height="20"
                            CornerRadius="10"
                            BorderBrush="#CCCCCC"
                            BorderThickness="1"
                            Background="Black">
                        <Grid>
                            <Border x:Name="InnerTrack"
                                    CornerRadius="8"
                                    Margin="2"
                                    Background="Transparent" />
                            <Ellipse x:Name="SwitchThumb"
                                     Fill="White"
                                     Width="12" Height="12"
                                     VerticalAlignment="Center"
                                     HorizontalAlignment="Left"
                                     Margin="3,0" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="InnerTrack" Property="Background" Value="#3A7BBF" />
                            <Setter TargetName="SwitchThumb" Property="HorizontalAlignment" Value="Right" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="OuterBorder" Property="BorderBrush" Value="White" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
      Boutons système de la barre de titre custom (WpsTitleBar) : minimize / maximize-restore /
      close. Hauteur fixe 36 (= CaptionHeight de la WindowChrome), largeur 46 (= standard Win11
      pour les caption buttons natifs). Foreground gris clair, hover overlay subtil.
      Le bouton Close a un hover spécifique rouge (#E81123, standard Windows).
    -->
    <Style x:Key="WpsTitleBarBtn" TargetType="Button">
        <Setter Property="Width" Value="46" />
        <Setter Property="Height" Value="36" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="#D0D6DE" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="Cursor" Value="Arrow" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#33FFFFFF" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#22FFFFFF" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
      ScrollBar style "Chrome/Apple-like" cohérent avec wipiLOG : thumb arrondi gris,
      flèches discrètes, ScaleTransform 0.75 pour rendre la scrollbar plus fine.
      Application via : <Style TargetType="ScrollBar" BasedOn="{StaticResource WpsScrollBarStyle}" />
      dans les Resources du ScrollViewer (ou globalement dans une Window/UserControl).
    -->
    <Style x:Key="WpsScrollThumbStyle" TargetType="Thumb">
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="ThumbBorder" Background="#999999"
                            CornerRadius="4" Margin="3,1" />
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ThumbBorder" Property="Background" Value="#CCCCCC" />
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="ThumbBorder" Property="Background" Value="White" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="WpsScrollArrowButtonStyle" TargetType="RepeatButton">
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Background="Transparent" Height="14" Width="14">
                        <Path x:Name="Arrow"
                              Data="{Binding Content, RelativeSource={RelativeSource TemplatedParent}}"
                              Fill="#999999"
                              HorizontalAlignment="Center" VerticalAlignment="Center"
                              StrokeThickness="0" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Arrow" Property="Fill" Value="White" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="WpsScrollPageButtonStyle" TargetType="RepeatButton">
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Background="Transparent" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <ControlTemplate x:Key="WpsScrollBarVerticalTemplate" TargetType="ScrollBar">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Border Grid.RowSpan="3" Background="{TemplateBinding Background}" />
            <RepeatButton Grid.Row="0"
                          Command="ScrollBar.LineUpCommand"
                          Content="M0,5 L4,0 L8,5Z"
                          Style="{StaticResource WpsScrollArrowButtonStyle}" />
            <Track Grid.Row="1" x:Name="PART_Track" IsDirectionReversed="True">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                  Style="{StaticResource WpsScrollPageButtonStyle}" />
                </Track.DecreaseRepeatButton>
                <Track.Thumb>
                    <Thumb Style="{StaticResource WpsScrollThumbStyle}" />
                </Track.Thumb>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                  Style="{StaticResource WpsScrollPageButtonStyle}" />
                </Track.IncreaseRepeatButton>
            </Track>
            <RepeatButton Grid.Row="2"
                          Command="ScrollBar.LineDownCommand"
                          Content="M0,0 L4,5 L8,0Z"
                          Style="{StaticResource WpsScrollArrowButtonStyle}" />
        </Grid>
    </ControlTemplate>

    <ControlTemplate x:Key="WpsScrollBarHorizontalTemplate" TargetType="ScrollBar">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Border Grid.ColumnSpan="3" Background="{TemplateBinding Background}" />
            <RepeatButton Grid.Column="0"
                          Command="ScrollBar.LineLeftCommand"
                          Content="M5,0 L0,4 L5,8Z"
                          Style="{StaticResource WpsScrollArrowButtonStyle}" />
            <Track Grid.Column="1" x:Name="PART_Track">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageLeftCommand"
                                  Style="{StaticResource WpsScrollPageButtonStyle}" />
                </Track.DecreaseRepeatButton>
                <Track.Thumb>
                    <Thumb Style="{StaticResource WpsScrollThumbStyle}" />
                </Track.Thumb>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageRightCommand"
                                  Style="{StaticResource WpsScrollPageButtonStyle}" />
                </Track.IncreaseRepeatButton>
            </Track>
            <RepeatButton Grid.Column="2"
                          Command="ScrollBar.LineRightCommand"
                          Content="M0,0 L5,4 L0,8Z"
                          Style="{StaticResource WpsScrollArrowButtonStyle}" />
        </Grid>
    </ControlTemplate>

    <!-- Style ScrollBar combiné : bascule template selon Orientation + ScaleTransform 0.75
         pour rendre la scrollbar plus fine (look wipiLOG / VS Code). -->
    <Style x:Key="WpsScrollBarStyle" TargetType="ScrollBar">
        <Setter Property="Background" Value="#252526" />
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Vertical">
                <Setter Property="Template" Value="{StaticResource WpsScrollBarVerticalTemplate}" />
                <Setter Property="LayoutTransform">
                    <Setter.Value>
                        <ScaleTransform ScaleX="0.75" />
                    </Setter.Value>
                </Setter>
            </Trigger>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Template" Value="{StaticResource WpsScrollBarHorizontalTemplate}" />
                <Setter Property="LayoutTransform">
                    <Setter.Value>
                        <ScaleTransform ScaleY="0.75" />
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="WpsTitleBarCloseBtn" TargetType="Button">
        <Setter Property="Width" Value="46" />
        <Setter Property="Height" Value="36" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="#D0D6DE" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="Cursor" Value="Arrow" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}">
                        <ContentPresenter x:Name="Cp" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#E81123" />
                            <Setter TargetName="Cp" Property="TextElement.Foreground" Value="White" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#C70F1B" />
                            <Setter TargetName="Cp" Property="TextElement.Foreground" Value="White" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
